# Local Development Environment Variables
# Copy this file to .env.local and update the values

# Database Configuration (Docker PostgreSQL)
DATABASE_URL="postgresql://dev_user:dev_password@localhost:5432/ready_set_dev"
DIRECT_URL="postgresql://dev_user:dev_password@localhost:5432/ready_set_dev"

# Test Database Configuration
TEST_DATABASE_URL="postgresql://test_user:test_password@localhost:5433/ready_set_test"

# Next.js Configuration
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-change-this-in-production"

# Supabase Configuration (for development - use mock values or local Supabase)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321" # Local Supabase URL if using supabase start
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Local file storage (instead of S3 for development)
UPLOAD_DIRECTORY="./uploads"
NEXT_PUBLIC_UPLOAD_URL="http://localhost:3000/uploads"

# Email Configuration (use Ethereal for development)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER="your-ethereal-username"
SMTP_PASS="your-ethereal-password"

# Stripe (use test keys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# SendGrid (optional)
SENDGRID_API_KEY="your-sendgrid-key"

# Highlight.run (optional for development)
HIGHLIGHT_PROJECT_API_KEY="your-highlight-key"

# Redis (if using caching)
REDIS_URL="redis://localhost:6379"

# Google APIs (if needed)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Development flags
SKIP_TYPECHECK="false"
DEBUG="ready-set:*"

# pgAdmin access (if using)
PGADMIN_URL="http://localhost:8080"
PGADMIN_EMAIL="admin@readyset.local"
PGADMIN_PASSWORD="admin123" 