{
  "name": "ready-set-nextjs",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' prisma generate && cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:no-typecheck": "cross-env NODE_OPTIONS='--max-old-space-size=4096' SKIP_TYPECHECK=true prisma generate && cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:custom": "node scripts/build-without-prisma-collect.js",
    "build:sourcemaps": "pnpm run build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "node scripts/type-check.js",
    "pre-push-check": "pnpm typecheck && pnpm prisma generate && pnpm lint",
    "check-build": "./scripts/check-build.sh",
    "prepare": "husky",
    "backup": "dotenv -e .env.production tsx scripts/backup-db.ts",
    "test": "jest",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:user-deletion": "scripts/test-user-deletion.sh all",
    "test:user-deletion:unit": "jest src/__tests__/api/users/userId-delete.test.ts --verbose",
    "test:console-cleanup": "node scripts/test-console-cleanup.js",
    "cleanup:console-logs": "node scripts/bulk-console-cleanup.js",
    "cleanup:console-targeted": "node scripts/targeted-console-cleanup.js",
    "analyze:console-logs": "node scripts/analyze-console-logs.js",
    "test:user-deletion:integration": "jest src/__tests__/integration/user-deletion-flow.integration.test.ts --verbose",
    "test:user-deletion:performance": "jest src/__tests__/performance/user-deletion-performance.test.ts --verbose --testTimeout=30000",
    "test:user-deletion:coverage": "jest src/__tests__/api/users/userId-delete.test.ts src/__tests__/integration/user-deletion-flow.integration.test.ts --coverage --collectCoverageFrom='src/app/api/users/[userId]/route.ts' --coverageDirectory='coverage/user-deletion'",
    "test:user-deletion:watch": "jest src/__tests__/api/users/userId-delete.test.ts --watch --verbose",
    "deploy:pre-checks": "scripts/deployment/pre-deployment-checks.sh",
    "deploy:backup": "scripts/deployment/backup-production-db.sh",
    "deploy:validate:dev": "scripts/deployment/development-deployment-validation.sh",
    "deploy:validate:staging": "scripts/deployment/staging-deployment-validation.sh",
    "deploy:monitor:prod": "scripts/deployment/production-deployment-monitor.sh",
    "deploy:rollback": "scripts/deployment/emergency-rollback.sh",
    "monitor:immediate": "scripts/monitoring/immediate-monitoring.sh",
    "monitor:long-term": "scripts/monitoring/long-term-monitoring.sh",
    "monitor:data-integrity": "scripts/monitoring/data-integrity-validator.sh",
    "monitor:usage-patterns": "scripts/monitoring/usage-pattern-analyzer.sh",
    "optimize:database": "psql $DATABASE_URL -f scripts/optimization/transaction-optimizer.sql",
    "studio": "dotenv -e .env.local -- npx prisma studio",
    "db:generate": "dotenv -e .env.local -- npx prisma generate",
    "prisma": "prisma generate",
    "postinstall": "node -e \"if (process.env.PRISMA_SKIP_POSTINSTALL_GENERATE !== 'true' && process.env.CI !== 'true') { try { require('child_process').execSync('prisma generate', { stdio: 'inherit' }); } catch (e) { console.log('Skipping prisma generate in postinstall:', e.message); } }\"",
    "vercel-build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' prisma generate && cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "vercel-sim": "node scripts/vercel-build-simulation.js",
    "type-check": "tsc --noEmit",
    "pre-push": "node scripts/type-check.js",
    "env:list": "tsx scripts/list-coolify-resources.ts",
    "env:sync": "tsx scripts/sync-env.ts",
    "test:address": "tsx scripts/test-address-creation.ts",
    "test:forms": "tsx scripts/test-nested-forms.ts",
    "calculator:migrate": "tsx scripts/apply-calculator-migration.ts",
    "calculator:migrate:force": "tsx scripts/apply-calculator-migration.ts --force",
    "calculator:migrate:status": "tsx scripts/apply-calculator-migration.ts --status",
    "calculator:data": "tsx scripts/migrate-calculator-data.ts",
    "calculator:data:force": "tsx scripts/migrate-calculator-data.ts --force",
    "calculator:test": "tsx scripts/migrate-calculator-data.ts --test",
    "calculator:setup": "pnpm calculator:migrate && pnpm db:generate && pnpm calculator:data && pnpm calculator:test"
  },
